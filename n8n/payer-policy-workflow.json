    {
      "parameters": {
        "jsCode": "// Get Claude's extraction and current rules from GitHub\nconst allItems = $input.all();\n\n// The Claude result comes through as text - parse it\nconst claudeItem = allItems[0];\nlet extracted;\ntry {\n  const text = claudeItem.json.message?.content || claudeItem.json.text || claudeItem.json.data || '';\n  extracted = JSON.parse(text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim());\n} catch (e) {\n  return [{ json: { hasChanges: false, message: 'Failed to parse Claude response: ' + e.message } }];\n}\n\nconst hasChanges = extracted.policies?.length > 0 && !extracted.noChangesDetected;\n\nif (!hasChanges) {\n  return [{ json: { hasChanges: false, message: extracted.summary || 'No policy changes detected' } }];\n}\n\nreturn [{\n  json: {\n    hasChanges: true,\n    changes: extracted.policies.map(p => `${p.payerId}: ${p.changeDetected || p.name}`),\n    summary: extracted.summary,\n    extractedPolicies: extracted.policies,\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
