    {
      "parameters": {
        "jsCode": "// Strip HTML tags, scripts, styles, and excess whitespace\n// Keeps just the text content, truncated to ~8000 chars per page\nconst items = $input.all();\nconst cleaned = items.map(item => {\n  let html = item.json.data || item.json.body || item.json.html || '';\n  \n  // Remove scripts, styles, nav, footer\n  html = html.replace(/<script[\\s\\S]*?<\\/script>/gi, '');\n  html = html.replace(/<style[\\s\\S]*?<\\/style>/gi, '');\n  html = html.replace(/<nav[\\s\\S]*?<\\/nav>/gi, '');\n  html = html.replace(/<footer[\\s\\S]*?<\\/footer>/gi, '');\n  html = html.replace(/<header[\\s\\S]*?<\\/header>/gi, '');\n  \n  // Strip remaining HTML tags\n  html = html.replace(/<[^>]+>/g, ' ');\n  \n  // Clean up whitespace\n  html = html.replace(/\\s+/g, ' ').trim();\n  \n  // Truncate to ~8000 chars\n  if (html.length > 8000) {\n    html = html.substring(0, 8000) + '... [truncated]';\n  }\n  \n  return { json: { text: html, url: item.json.url || 'unknown' } };\n});\n\nreturn cleaned;\n"
      },
